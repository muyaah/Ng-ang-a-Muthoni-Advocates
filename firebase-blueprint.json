{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Legal consultation booking",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "service", "date"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "Legal insight article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "image": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["title", "content", "author", "date"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of consultation bookings"
    },
    "/posts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of blog posts"
    }
  }
}
