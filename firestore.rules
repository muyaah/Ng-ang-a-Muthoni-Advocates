rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
              (request.auth.token.email == "muyaahpeninah@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidBooking(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.email is string &&
             data.service is string &&
             data.date is string;
    }

    match /bookings/{bookingId} {
      allow create: if isValidBooking(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
  }
}
